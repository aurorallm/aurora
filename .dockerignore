# ===================
# Runtime data (except vendored model files)
# ===================
# Exclude runtime-generated data (SQLite DB, logs) but keep the vendored
# model registry snapshot and user pricing overrides so the image can load
# them synchronously at startup without a network fetch.
data/
!data/models.local.json
!data/user_pricing.yaml

