# Aurora OSS local power-user env example
# Pair with configs/editions/oss.local-power.example.yaml.
# Usage:
#   cp configs/editions/oss.local-power.env.example .env
#   AURORA_CONFIG_PATH=configs/editions/oss.local-power.example.yaml go run ./apps/aurora
#
# This profile uses SQLite plus Redis exact response cache, audit logging,
# usage tracking, Prometheus metrics, and optional guardrails/token saver.

AURORA_CONFIG_PATH=configs/editions/oss.local-power.example.yaml
AURORA_MASTER_KEY=replace-with-local-master-key
PORT=8080
BASE_PATH=/
LOG_FORMAT=text
LOG_LEVEL=info

# Dashboard/admin API.
ADMIN_ENDPOINTS_ENABLED=true
ADMIN_UI_ENABLED=true


# SQLite storage and local model cache.
STORAGE_TYPE=sqlite
SQLITE_PATH=data/aurora-oss-power.db
AURORA_CACHE_DIR=.cache
MODEL_LIST_URL=
MODEL_LIST_LOCAL_PATH=data/models.local.json
MODEL_LIST_USER_OVERRIDES_PATH=data/user_pricing.yaml

# Redis is required by cache.response.simple in oss.local-power.example.yaml.
REDIS_URL=redis://localhost:6379
REDIS_KEY_RESPONSES=aurora:response:
REDIS_TTL_RESPONSES=3600
RESPONSE_CACHE_SIMPLE_ENABLED=true

# Semantic cache stays off in local-power. Use oss.team for the complete semantic profile.
SEMANTIC_CACHE_ENABLED=false

# Routing/model inventory.
ENABLE_PASSTHROUGH_ROUTES=true
ALLOW_PASSTHROUGH_V1_ALIAS=true
ENABLED_PASSTHROUGH_PROVIDERS=openai,anthropic,openrouter,zai,vllm
ENABLE_ANTHROPIC_INGRESS=true
MODELS_ENABLED_BY_DEFAULT=true
MODEL_OVERRIDES_ENABLED=true
KEEP_ONLY_ALIASES_AT_MODELS_ENDPOINT=false
CONFIGURED_PROVIDER_MODELS_MODE=fallback

# Audit/usage/metrics.
LOGGING_ENABLED=true
LOGGING_LOG_BODIES=false
LOGGING_LOG_HEADERS=false
LOGGING_ONLY_MODEL_INTERACTIONS=true
LOGGING_BUFFER_SIZE=1000
LOGGING_FLUSH_INTERVAL=5
LOGGING_RETENTION_DAYS=30
USAGE_ENABLED=true
USAGE_PRICING_RECALCULATION_ENABLED=true
ENFORCE_RETURNING_USAGE_DATA=true
USAGE_BUFFER_SIZE=1000
USAGE_FLUSH_INTERVAL=5
USAGE_RETENTION_DAYS=90
METRICS_ENABLED=true
METRICS_ENDPOINT=/metrics
PPROF_ENABLED=false
SWAGGER_ENABLED=false

# Optional OSS features.
GUARDRAILS_ENABLED=false
ENABLE_GUARDRAILS_FOR_BATCH_PROCESSING=false
COMBOS_ENABLED=true
CLI_TOOLS_ENABLED=true
CLI_TOOLS_APPLY_ENABLED=false
TOKEN_SAVER_ENABLED=false
TOKEN_SAVER_ENDPOINTS=chat_completions
TOKEN_SAVER_APPLY_STREAMING=true
TOKEN_SAVER_OUTPUT_ENABLED=false
TOKEN_SAVER_OUTPUT_PROFILE=concise
TOKEN_SAVER_OUTPUT_LEVEL=full
TOKEN_SAVER_ON_ERROR=allow
TOKEN_SAVER_EMIT_HEADERS=true
TOKEN_SAVER_AUDIT_ENABLED=true
WORKFLOW_REFRESH_INTERVAL=1m

# Resilience defaults matching the YAML profile/code defaults.
RETRY_MAX_RETRIES=3
RETRY_INITIAL_BACKOFF=1s
RETRY_MAX_BACKOFF=30s
RETRY_BACKOFF_FACTOR=2.0
RETRY_JITTER_FACTOR=0.1
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_SUCCESS_THRESHOLD=2
CIRCUIT_BREAKER_TIMEOUT=30s

# Provider credentials. Set at least one provider to make model calls.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
XAI_API_KEY=
AZURE_API_KEY=
AZURE_BASE_URL=
AZURE_API_VERSION=2024-10-21
ORACLE_API_KEY=
ORACLE_BASE_URL=
OLLAMA_BASE_URL=http://localhost:11434/v1
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=
