# Aurora OSS self-hosted team env example
# Pair with configs/editions/oss.team.example.yaml.
# Usage:
#   cp configs/editions/oss.team.env.example .env
#   AURORA_CONFIG_PATH=configs/editions/oss.team.example.yaml go run ./apps/aurora
#
# This profile enables the full OSS operations stack: Postgres storage,
# Redis model/exact cache, Qdrant semantic cache, audit logging, usage,
# metrics, fallback, resilience, provider examples, token saver examples,
# and provider-pool examples in YAML.

AURORA_CONFIG_PATH=configs/editions/oss.team.example.yaml
AURORA_MASTER_KEY=replace-with-team-master-key
PORT=8080
BASE_PATH=/
LOG_FORMAT=text
LOG_LEVEL=info

# Dashboard/admin API.
ADMIN_ENDPOINTS_ENABLED=true
ADMIN_UI_ENABLED=true


# Required infrastructure for oss.team.example.yaml.
STORAGE_TYPE=postgresql
POSTGRES_URL=postgres://aurora:aurora@localhost:5432/aurora?sslmode=disable
POSTGRES_MAX_CONNS=20
POSTGRES_DB=aurora
REDIS_URL=redis://localhost:6379

# Model registry cache in Redis.
REDIS_KEY_MODELS=aurora:models
REDIS_TTL_MODELS=86400
CACHE_REFRESH_INTERVAL=3600
MODEL_LIST_URL=
MODEL_LIST_LOCAL_PATH=data/models.local.json
MODEL_LIST_USER_OVERRIDES_PATH=data/user_pricing.yaml

# Exact response cache in Redis.
RESPONSE_CACHE_SIMPLE_ENABLED=true
REDIS_KEY_RESPONSES=aurora:response:
REDIS_TTL_RESPONSES=3600

# Semantic response cache. Default YAML uses Qdrant.
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_THRESHOLD=0.92
SEMANTIC_CACHE_PROMPT_SIMILARITY=0.72
SEMANTIC_CACHE_TTL=3600
SEMANTIC_CACHE_MAX_CONV_MESSAGES=3
SEMANTIC_CACHE_EXCLUDE_SYSTEM_PROMPT=true
SEMANTIC_CACHE_EMBEDDER_PROVIDER=jina
SEMANTIC_CACHE_EMBEDDER_MODEL=jina-embeddings-v3
SEMANTIC_CACHE_VECTOR_STORE_TYPE=qdrant
SEMANTIC_CACHE_QDRANT_URL=http://localhost:6333
SEMANTIC_CACHE_QDRANT_COLLECTION=aurora_semantic
SEMANTIC_CACHE_QDRANT_API_KEY=

# Alternative semantic vector stores. Only set the block matching SEMANTIC_CACHE_VECTOR_STORE_TYPE.
SEMANTIC_CACHE_PGVECTOR_URL=
SEMANTIC_CACHE_PGVECTOR_TABLE=aurora_semantic_cache
SEMANTIC_CACHE_PGVECTOR_DIMENSION=1536
SEMANTIC_CACHE_PINECONE_HOST=
SEMANTIC_CACHE_PINECONE_API_KEY=
SEMANTIC_CACHE_PINECONE_NAMESPACE=
SEMANTIC_CACHE_PINECONE_DIMENSION=1536
SEMANTIC_CACHE_WEAVIATE_URL=
SEMANTIC_CACHE_WEAVIATE_CLASS=AuroraSemanticCache
SEMANTIC_CACHE_WEAVIATE_API_KEY=

# Routing/model inventory.
ENABLE_PASSTHROUGH_ROUTES=true
ALLOW_PASSTHROUGH_V1_ALIAS=true
ENABLED_PASSTHROUGH_PROVIDERS=openai,anthropic,openrouter,zai,vllm
ENABLE_ANTHROPIC_INGRESS=true
MODELS_ENABLED_BY_DEFAULT=true
MODEL_OVERRIDES_ENABLED=true
KEEP_ONLY_ALIASES_AT_MODELS_ENDPOINT=false
CONFIGURED_PROVIDER_MODELS_MODE=fallback

# Audit/usage/metrics.
LOGGING_ENABLED=true
LOGGING_LOG_BODIES=false
LOGGING_LOG_HEADERS=false
LOGGING_ONLY_MODEL_INTERACTIONS=true
LOGGING_BUFFER_SIZE=1000
LOGGING_FLUSH_INTERVAL=5
LOGGING_RETENTION_DAYS=30
USAGE_ENABLED=true
USAGE_PRICING_RECALCULATION_ENABLED=true
ENFORCE_RETURNING_USAGE_DATA=true
USAGE_BUFFER_SIZE=1000
USAGE_FLUSH_INTERVAL=5
USAGE_RETENTION_DAYS=90
METRICS_ENABLED=true
METRICS_ENDPOINT=/metrics
PPROF_ENABLED=false
SWAGGER_ENABLED=false

# Fallback/workflow/resilience settings matching oss.team.example.yaml.
FEATURE_FALLBACK_MODE=manual
FALLBACK_MANUAL_RULES_PATH=configs/fallback.example.json
WORKFLOW_REFRESH_INTERVAL=1m
RETRY_MAX_RETRIES=3
RETRY_INITIAL_BACKOFF=1s
RETRY_MAX_BACKOFF=30s
RETRY_BACKOFF_FACTOR=2.0
RETRY_JITTER_FACTOR=0.1
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_SUCCESS_THRESHOLD=2
CIRCUIT_BREAKER_TIMEOUT=30s

# Optional OSS features.
GUARDRAILS_ENABLED=false
ENABLE_GUARDRAILS_FOR_BATCH_PROCESSING=false
COMBOS_ENABLED=true
CLI_TOOLS_ENABLED=true
CLI_TOOLS_APPLY_ENABLED=false
TOKEN_SAVER_ENABLED=false
TOKEN_SAVER_ENDPOINTS=chat_completions
TOKEN_SAVER_APPLY_STREAMING=true
TOKEN_SAVER_OUTPUT_ENABLED=false
TOKEN_SAVER_OUTPUT_PROFILE=concise
TOKEN_SAVER_OUTPUT_LEVEL=full
TOKEN_SAVER_ON_ERROR=allow
TOKEN_SAVER_EMIT_HEADERS=true
TOKEN_SAVER_AUDIT_ENABLED=true

# Provider credentials. Set providers your team uses.
OPENAI_API_KEY=
OPENAI_MODELS=gpt-4o-mini
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
XAI_API_KEY=
AZURE_API_KEY=
AZURE_BASE_URL=
AZURE_API_VERSION=2024-10-21
ORACLE_API_KEY=
ORACLE_BASE_URL=
OLLAMA_BASE_URL=http://localhost:11434/v1
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=

# Jina provider used by the semantic-cache embedder example above.
JINA_API_KEY=
JINA_BASE_URL=https://api.jina.ai/v1
JINA_MODELS=jina-embeddings-v3

# Optional multiple-instance provider examples for pools in oss.team.example.yaml.
# Uncomment the YAML pool and set these to use model prefix openai-pool/<model>.
OPENAI_EAST_API_KEY=
OPENAI_EAST_BASE_URL=https://api.openai.com/v1
OPENAI_EAST_MODELS=gpt-4o-mini
OPENAI_WEST_API_KEY=
OPENAI_WEST_BASE_URL=https://api.openai.com/v1
OPENAI_WEST_MODELS=gpt-4o-mini
