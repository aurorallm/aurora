{
  "name": "aurora-ui",
  "version": "1.0.35",
  "private": true,
  "type": "module",
  "description": "Aurora admin dashboard — Vite + React 19 + TypeScript SPA. Built output is embedded into the Go binary via internal/admin/dashboard/dist.",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --disable-react-plugin src",
    "format": "oxfmt src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/dm-serif-display": "^5.2.8",
    "@fontsource/inter": "5.1.0",
    "@radix-ui/react-dialog": "1.1.2",
    "@radix-ui/react-dropdown-menu": "2.1.2",
    "@radix-ui/react-label": "2.1.0",
    "@radix-ui/react-select": "2.1.2",
    "@radix-ui/react-slot": "1.1.0",
    "@radix-ui/react-tabs": "1.1.1",
    "@radix-ui/react-tooltip": "1.1.4",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@tanstack/react-query": "5.62.0",
    "@tanstack/react-router": "1.91.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "0.460.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "recharts": "2.13.3",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "2.5.5",
    "three": "^0.184.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "4.0.0-beta.7",
    "@tanstack/router-devtools": "1.91.1",
    "@tanstack/router-plugin": "1.91.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@types/node": "22.10.1",
    "@types/react": "19.0.1",
    "@types/react-dom": "19.0.1",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "4.3.4",
    "happy-dom": "15.11.7",
    "oxlint": "0.13.1",
    "tailwindcss": "4.0.0-beta.7",
    "tw-animate-css": "1.4.0",
    "typescript": "5.7.2",
    "vite": "6.0.3",
    "vitest": "2.1.8"
  }
}
